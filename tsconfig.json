{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/workers/*": [
        "./workers/*"
      ],
      "@/*": [
        "./src/*",
        "./*"
      ]
    }
  },
  "include": [
    "src",
    "test",
    "workers",
    "vite.config.ts",
    "vitest.config.ts",
    "tailwind.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
