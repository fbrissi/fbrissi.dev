{
  "name": "fbrissi-dev",
  "private": true,
  "version": "0.1.0",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build:resumes": "node scripts/build-resumes.mjs",
    "build:seo": "node scripts/build-seo.mjs",
    "generate": "node scripts/build-content-data.mjs && yarn build:resumes && yarn build:seo",
    "predev": "yarn generate",
    "pretypecheck": "node scripts/build-content-data.mjs",
    "pretest": "node scripts/build-content-data.mjs",
    "pretest:coverage": "node scripts/build-content-data.mjs",
    "dev": "next dev",
    "prebuild": "yarn generate",
    "build": "next build",
    "preview": "next dev",
    "dev:contact-api": "tsx workers/local/contact-api.ts",
    "dev:contact-email-consumer": "tsx workers/local/contact-email-consumer.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1085.0",
    "axios": "1.18.1",
    "highlight.js": "^11.11.1",
    "next": "16.3.0-preview.8",
    "nodemailer": "^9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^9.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "3.2.6",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "pdfkit": "^0.19.1",
    "postcss": "^8.5.16",
    "tailwindcss": "3",
