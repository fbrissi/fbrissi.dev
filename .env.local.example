# Local Development Environment
# Copy this file to .env.local for local development

# Turnstile test key (always passes validation)
# https://developers.cloudflare.com/turnstile/reference/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Used by the browser only during local development. Docker Compose sets this
# automatically; set it when running Next.js outside Docker.
# NEXT_PUBLIC_CONTACT_API_URL=http://localhost:8787/api/contact
