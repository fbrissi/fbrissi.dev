# Cloudflare Turnstile (anti-spam protection)
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# For local development, use the test key (always passes): 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Local Development
# `kool start` runs the contact API, LocalStack SQS, and Mailpit automatically.
# Next.js sends contact requests to the local API URL configured by Docker Compose,
# and the consumer sends queued messages to Mailpit's SMTP server.

# Production secrets (managed by Terraform or Cloudflare dashboard)
# DO NOT set these in .env.local - they are set via Terraform variables
#
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
# CONTACT_EMAIL_TO=hello@fbrissi.dev
# CONTACT_EMAIL_FROM=noreply@fbrissi.dev
